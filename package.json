{
  "name": "@syfxlin/eslint-config",
  "type": "module",
  "version": "0.0.0-semantic-release",
  "description": "Otstar's ESLint config",
  "author": "Otstar Lin <i@ixk.me> (https://github.com/syfxlin)",
  "license": "MIT",
  "homepage": "https://github.com/syfxlin/eslint-config",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/syfxlin/eslint-config.git"
  },
  "bugs": {
    "url": "https://github.com/syfxlin/eslint-config/issues"
  },
  "keywords": [
    "eslint",
    "eslint-config"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bunchee",
    "dev": "bunchee --watch",
    "dev:viewer": "config-inspector",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0"
  },
  "dependencies": {
    "@antfu/eslint-config": "8.2.0",
    "@eslint-react/eslint-plugin": "^3.0.0",
    "@unocss/eslint-plugin": "^66.6.8",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-svelte": "^3.17.1",
    "eslint-plugin-tailwindcss": "^3.18.3",
    "svelte-eslint-parser": "^1.6.0"
  },
  "devDependencies": {
    "@eslint/config-inspector": "^2.0.0",
    "@types/eslint-plugin-tailwindcss": "^3.17.0",
    "bunchee": "^6.10.0",
    "eslint": "^10.2.1"
  }
}
